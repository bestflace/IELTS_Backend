generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["partialIndexes"]
}

datasource db {
  provider = "postgresql"
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model ai_gradings {
  id                     String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  attempt_id             String             @db.VarChar(32)
  skill                  test_type
  provider               String             @default("GEMINI") @db.VarChar(50)
  status                 grading_job_status @default(PENDING)
  request_json           Json?
  response_json          Json?
  normalized_result_json Json?
  error_message          String?
  retry_count            Int                @default(0)
  bull_job_id            String?            @unique(map: "uq_ai_gradings_bull_job_id", where: raw("(bull_job_id IS NOT NULL)"))
  dedupe_key             String?            @unique(map: "uq_ai_gradings_dedupe_key", where: raw("(dedupe_key IS NOT NULL)"))
  started_at             DateTime?          @db.Timestamptz(6)
  finished_at            DateTime?          @db.Timestamptz(6)
  created_at             DateTime           @default(now()) @db.Timestamptz(6)
  updated_at             DateTime           @default(now()) @db.Timestamptz(6)
  attempts               attempts           @relation(fields: [attempt_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([attempt_id, skill, provider], map: "uq_ai_gradings_attempt_skill_provider")
  @@index([attempt_id], map: "idx_ai_gradings_attempt")
  @@index([status, created_at], map: "idx_ai_gradings_status")
}

model asr_jobs {
  id                           String                     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  attempt_id                   String                     @db.VarChar(32)
  attempt_speaking_response_id String                     @db.Uuid
  speaking_part                speaking_part_type
  provider                     String                     @default("WHISPER") @db.VarChar(50)
  status                       grading_job_status         @default(PENDING)
  request_json                 Json?
  response_json                Json?
  error_message                String?
  retry_count                  Int                        @default(0)
  bull_job_id                  String?                    @unique(map: "uq_asr_jobs_bull_job_id", where: raw("(bull_job_id IS NOT NULL)"))
  dedupe_key                   String?                    @unique(map: "uq_asr_jobs_dedupe_key", where: raw("(dedupe_key IS NOT NULL)"))
  started_at                   DateTime?                  @db.Timestamptz(6)
  finished_at                  DateTime?                  @db.Timestamptz(6)
  created_at                   DateTime                   @default(now()) @db.Timestamptz(6)
  updated_at                   DateTime                   @default(now()) @db.Timestamptz(6)
  attempts                     attempts                   @relation(fields: [attempt_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  attempt_speaking_responses   attempt_speaking_responses @relation(fields: [attempt_speaking_response_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([attempt_speaking_response_id, provider], map: "uq_asr_jobs_response_provider")
  @@index([attempt_id], map: "idx_asr_jobs_attempt")
  @@index([status, created_at], map: "idx_asr_jobs_status")
  @@index([attempt_speaking_response_id], map: "idx_asr_jobs_response")
}

model attempt_comments {
  id                     String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  attempt_id             String             @db.VarChar(32)
  user_id                String             @db.Uuid
  parent_id              String?            @db.Uuid
  content                String
  status                 comment_status     @default(ACTIVE)
  created_at             DateTime           @default(now()) @db.Timestamptz(6)
  updated_at             DateTime           @default(now()) @db.Timestamptz(6)
  deleted_at             DateTime?          @db.Timestamptz(6)
  attempts               attempts           @relation(fields: [attempt_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  attempt_comments       attempt_comments?  @relation("attempt_commentsToattempt_comments", fields: [parent_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  other_attempt_comments attempt_comments[] @relation("attempt_commentsToattempt_comments")
  users                  users              @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([attempt_id, created_at], map: "idx_attempt_comments_attempt")
  @@index([parent_id], map: "idx_attempt_comments_parent")
  @@index([user_id, created_at(sort: Desc)], map: "idx_attempt_comments_user")
}

model attempt_question_answers {
  id          String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  attempt_id  String     @db.VarChar(32)
  question_id String?    @db.Uuid
  section_key String?    @db.VarChar(80)
  q_no        Int?
  answer_json Json       @default("{}")
  is_flagged  Boolean    @default(false)
  is_final    Boolean    @default(false)
  saved_at    DateTime   @default(now()) @db.Timestamptz(6)
  attempts    attempts   @relation(fields: [attempt_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  questions   questions? @relation(fields: [question_id], references: [id], onUpdate: NoAction)

  @@unique([attempt_id, question_id], map: "uq_attempt_question")
  @@index([attempt_id, saved_at(sort: Desc)], map: "idx_attempt_question_answers_attempt")
  @@index([attempt_id, section_key, q_no], map: "idx_attempt_question_answers_section_qno")
}

model attempt_result_details {
  id               String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  attempt_id       String     @db.VarChar(32)
  question_id      String?    @db.Uuid
  section_key      String?    @db.VarChar(80)
  q_no             Int?
  user_answer_json Json?
  correct_json     Json?
  is_correct       Boolean?
  points_awarded   Decimal?   @db.Decimal(6, 2)
  explanation      String?
  created_at       DateTime   @default(now()) @db.Timestamptz(6)
  attempts         attempts   @relation(fields: [attempt_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  questions        questions? @relation(fields: [question_id], references: [id], onUpdate: NoAction)

  @@unique([attempt_id, question_id], map: "uq_attempt_result_detail")
  @@index([attempt_id], map: "idx_attempt_result_details_attempt")
  @@index([attempt_id, section_key, q_no], map: "idx_attempt_result_details_section_qno")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model attempt_results {
