  @@index([status], map: "idx_attempts_status")
  @@index([test_id], map: "idx_attempts_test")
  @@index([user_id, created_at(sort: Desc)], map: "idx_attempts_user")
  @@index([expires_at], map: "idx_attempts_expires_at")
