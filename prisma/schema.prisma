  attempts           attempts @relation(fields: [attempt_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model attempt_speaking_responses {
  id                    String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  attempt_id            String             @db.VarChar(32)
  speaking_part         speaking_part_type
  prompt_id             String?            @db.Uuid
  audio_url             String
  audio_file_id         String?            @db.Uuid
  audio_file_key        String?
  audio_mime_type       String?            @db.VarChar(150)
  audio_size_bytes      BigInt?
  audio_etag            String?
  transcript            String?
  transcript_source     transcript_source  @default(WHISPER)
  whisper_response_json Json?
  duration_sec          Int?
  asr_status            grading_job_status @default(PENDING)
  asr_provider          String             @default("WHISPER") @db.VarChar(50)
  asr_error_message     String?
  asr_started_at        DateTime?          @db.Timestamptz(6)
  asr_finished_at       DateTime?          @db.Timestamptz(6)
  created_at            DateTime           @default(now()) @db.Timestamptz(6)
  updated_at            DateTime           @default(now()) @db.Timestamptz(6)
  asr_jobs              asr_jobs[]
  attempts              attempts           @relation(fields: [attempt_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  uploaded_files        uploaded_files?    @relation(fields: [audio_file_id], references: [id], onUpdate: NoAction)
  speaking_prompts      speaking_prompts?  @relation(fields: [prompt_id], references: [id], onUpdate: NoAction)

  @@unique([attempt_id, speaking_part], map: "uq_attempt_speaking_part")
  @@index([attempt_id], map: "idx_attempt_speaking_attempt")
  @@index([attempt_id, asr_status], map: "idx_attempt_speaking_asr_status")
  @@index([audio_file_id], map: "idx_attempt_speaking_audio_file")
}

model attempt_writing_responses {
  id              String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  attempt_id      String        @db.VarChar(32)
  writing_task_id String        @db.VarChar(32)
  response_text   String?
  word_count      Int?
  saved_at        DateTime      @default(now()) @db.Timestamptz(6)
  updated_at      DateTime      @default(now()) @db.Timestamptz(6)
  attempts        attempts      @relation(fields: [attempt_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  writing_tasks   writing_tasks @relation(fields: [writing_task_id], references: [id], onUpdate: NoAction)

  @@unique([attempt_id, writing_task_id], map: "uq_attempt_writing_task")
