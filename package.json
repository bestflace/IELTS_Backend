{
  "name": "ielts_backend",
  "version": "1.0.0",
  "description": "IELTS backend with Express, TypeScript, Prisma, PostgreSQL",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "prisma:init": "prisma init",
    "prisma:pull": "prisma db pull",
    "prisma:generate": "prisma generate",
    "prisma:studio": "prisma studio",
    "worker:all": "ts-node-dev --respawn --transpile-only src/jobs/workers/index.ts",
    "worker:import": "ts-node-dev --respawn --transpile-only src/jobs/workers/import.worker.ts",
    "worker:asr": "ts-node-dev --respawn --transpile-only src/jobs/workers/asr.worker.ts",
    "worker:grading": "ts-node-dev --respawn --transpile-only src/jobs/workers/grading.worker.ts",
    "worker:notification": "ts-node-dev --respawn --transpile-only src/jobs/workers/notification.worker.ts",
    "worker:all:prod": "node dist/jobs/workers/index.js",
    "worker:import:prod": "node dist/jobs/workers/import.worker.js",
    "worker:asr:prod": "node dist/jobs/workers/asr.worker.js",
    "worker:grading:prod": "node dist/jobs/workers/grading.worker.js",
    "worker:notification:prod": "node dist/jobs/workers/notification.worker.js",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "db:seed": "ts-node prisma/seed.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1019.0",
    "@aws-sdk/s3-request-presigner": "^3.1019.0",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.71.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dayjs": "^1.11.20",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "ms": "^2.1.3",
    "multer": "^2.1.1",
    "pg": "^8.20.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^13.0.0",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/ms": "^2.1.0",
    "@types/node": "^25.5.0",
    "@types/supertest": "^7.2.0",
    "@types/swagger-ui-express": "^4.1.8",
    "jest": "^30.3.0",
    "prisma": "^7.5.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3"
  }
}
